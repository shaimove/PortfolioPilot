# Copy to .env to enable the optional LLM and LangSmith integrations.
# The system runs fully WITHOUT any of these (deterministic fallbacks).

# --- LLM (OpenAI) ---
# If set, the portfolio decision agent and the LLM-as-judge use this model.
OPENAI_API_KEY=
PORTFOLIOPILOT_MODEL=gpt-4o-mini

# --- LangSmith tracing ---
# If set, monthly rebalance runs (agent + judge) are traced to LangSmith.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=portfoliopilot
